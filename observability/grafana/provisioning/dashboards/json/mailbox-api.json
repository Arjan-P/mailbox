{
  "title": "Mailbox API — Overview",
  "uid": "mailbox-api-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "tags": ["mailbox", "nodejs"],
  "panels": [

    {
      "id": 1,
      "type": "row",
      "title": "HTTP Traffic",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 2,
      "title": "Request Rate (req/s)",
      "description": "Requests per second by route and status code",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 1, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "sum by (route, status_code) (rate(http_request_duration_seconds_count[1m]))",
          "legendFormat": "{{route}} {{status_code}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "title": "Error Rate (5xx %)",
      "description": "Percentage of requests returning 5xx errors per route",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 1, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "expr": "sum by (route) (rate(http_request_duration_seconds_count{status_code=~\"5..\"}[1m])) / sum by (route) (rate(http_request_duration_seconds_count[1m]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "title": "P50 Latency by Route",
      "description": "Median request latency per route (histogram_quantile)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 9, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 8 }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (route, le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{route}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 5,
      "title": "P90 Latency by Route",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 9, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 8 }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.90, sum by (route, le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p90 {{route}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 6,
      "title": "P99 Latency by Route",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 9, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          },
          "custom": { "lineWidth": 2, "fillOpacity": 8 }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (route, le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 {{route}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 7,
      "type": "row",
      "title": "Node.js Process",
      "gridPos": { "x": 0, "y": 17, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 8,
      "title": "CPU Usage",
      "description": "Rate of CPU seconds consumed (user + system)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 18, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "rate(process_cpu_user_seconds_total[1m])",
          "legendFormat": "user",
          "refId": "A"
        },
        {
          "expr": "rate(process_cpu_system_seconds_total[1m])",
          "legendFormat": "system",
          "refId": "B"
        }
      ]
    },

    {
      "id": 9,
      "title": "Memory",
      "description": "RSS (resident) and heap used",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 18, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "process_resident_memory_bytes",
          "legendFormat": "RSS",
          "refId": "A"
        },
        {
          "expr": "nodejs_heap_size_used_bytes",
          "legendFormat": "Heap Used",
          "refId": "B"
        },
        {
          "expr": "nodejs_heap_size_total_bytes",
          "legendFormat": "Heap Total",
          "refId": "C"
        }
      ]
    },

    {
      "id": 10,
      "title": "Event Loop Lag",
      "description": "P50/P90/P99 event loop lag. >100 ms indicates a blocked loop.",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 18, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.1 }
            ]
          },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "nodejs_eventloop_lag_p50_seconds",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "nodejs_eventloop_lag_p90_seconds",
          "legendFormat": "p90",
          "refId": "B"
        },
        {
          "expr": "nodejs_eventloop_lag_p99_seconds",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },

    {
      "id": 11,
      "title": "Open File Descriptors",
      "description": "Watch for growth toward the max (524288)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 25, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "process_open_fds",
          "legendFormat": "open fds",
          "refId": "A"
        },
        {
          "expr": "process_max_fds",
          "legendFormat": "max fds",
          "refId": "B"
        }
      ]
    },

    {
      "id": 12,
      "title": "GC Duration (rate)",
      "description": "Time spent in GC per second by collection kind",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 25, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "rate(nodejs_gc_duration_seconds_sum[1m])",
          "legendFormat": "{{kind}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 13,
      "title": "Active Handles & Resources",
      "description": "Libuv handles and async resources keeping the loop alive",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 25, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "nodejs_active_handles_total",
          "legendFormat": "handles",
          "refId": "A"
        },
        {
          "expr": "nodejs_active_resources_total",
          "legendFormat": "resources",
          "refId": "B"
        }
      ]
    },

    {
      "id": 14,
      "type": "row",
      "title": "At-a-glance Stats",
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 15,
      "title": "Total Requests (all time)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 33, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "targets": [
        {
          "expr": "sum(http_request_duration_seconds_count)",
          "legendFormat": "",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "id": 16,
      "title": "5xx Errors (all time)",
      "type": "stat",
      "gridPos": { "x": 4, "y": 33, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(http_request_duration_seconds_count{status_code=~\"5..\"})",
          "legendFormat": "",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "id": 17,
      "title": "Heap Used %",
      "type": "gauge",
      "gridPos": { "x": 8, "y": 33, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.75 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "nodejs_heap_size_used_bytes / nodejs_heap_size_total_bytes",
          "legendFormat": "",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "id": 18,
      "title": "Event Loop Lag (current p99)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 33, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "nodejs_eventloop_lag_p99_seconds",
          "legendFormat": "",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "id": 19,
      "title": "RSS Memory",
      "type": "stat",
      "gridPos": { "x": 16, "y": 33, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 400000000 },
              { "color": "red", "value": 800000000 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "process_resident_memory_bytes",
          "legendFormat": "",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "id": 20,
      "title": "Process Uptime",
      "type": "stat",
      "gridPos": { "x": 20, "y": 33, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "targets": [
        {
          "expr": "time() - process_start_time_seconds",
          "legendFormat": "",
          "refId": "A",
          "instant": true
        }
      ]
    }

  ],

  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Datasource",
        "hide": 0,
        "current": {}
      }
    ]
  },

  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0,211,255,1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  }
}
