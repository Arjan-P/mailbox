{
  "name": "fastify-app",
  "version": "1.0.0",
  "type": "module",
  "description": "This project was bootstrapped with Fastify-CLI.",
  "main": "app.ts",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "npm run build:ts && tsc -p test/tsconfig.json && c8 node --test -r ts-node/register \"test/**/*.ts\"",
    "build:ts": "tsc",
    "watch:ts": "tsc -w",
    "start": "npm run build:ts && node --import dist/instrumentation.js dist/server.js",
    "dev": "npm run build:ts && concurrently -k -p \"[{name}]\" -n \"TypeScript,App\" -c \"yellow.bold,cyan.bold\" \"npm:watch:ts\" \"npm:dev:start\"",
    "dev:start": "node --watch --import ./dist/instrumentation.js dist/server.js",
    "start:worker": "node dist/workers/clerk.worker.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@clerk/fastify": "^3.1.22",
    "@fastify/autoload": "^6.0.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/oauth2": "^8.2.0",
    "@fastify/sensible": "^6.0.0",
    "@fastify/type-provider-zod": "^1.0.0",
    "@opentelemetry/auto-instrumentations-node": "^0.75.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.217.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.217.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@prisma/client": "5.22.0",
    "bullmq": "^5.76.5",
    "dotenv": "^17.4.2",
    "fastify": "^5.0.0",
    "fastify-cli": "^8.0.0",
    "fastify-metrics": "^13.2.0",
    "fastify-plugin": "^5.0.0",
    "fastify-raw-body": "^5.0.0",
    "googleapis": "^171.4.0",
    "install": "^0.13.0",
    "ioredis": "^5.10.1",
    "npm": "^11.13.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/dotenv": "^6.1.1",
    "@types/node": "^25.6.0",
    "c8": "^11.0.0",
    "concurrently": "^9.0.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "fastify-tsconfig": "^3.0.0",
    "prisma": "5.22.0",
    "ts-node": "^10.4.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.59.0"
  }
}
